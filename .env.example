# TriageIQ environment variables
# Copy to .env at the repository root (or backend/.env).
# Never commit real secrets.

# =============================================================================
# Backend (FastAPI) — read by app/core/config.py
# =============================================================================

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017

# Database name
MONGODB_DB=triagemiq

# Required: secret key for JWT signing (use a long random string in production)
JWT_SECRET=replace-with-a-strong-random-secret

# JWT settings
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Application environment
APP_ENV=development

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# =============================================================================
# Backend tests only (pytest — see backend/tests/conftest.py)
# =============================================================================

# Isolated test database name (do not use production DB name without explicit override)
TEST_MONGODB_DB=triageiq_test

# =============================================================================
# Frontend (Vite) — prefix with VITE_ for browser exposure
# =============================================================================

# Backend API URL as seen by the browser
VITE_API_BASE_URL=http://localhost:8000

# =============================================================================
# Docker Compose overrides (optional)
# =============================================================================
# Docker Compose sets MONGODB_URI=mongodb://mongo:27017/triageiq automatically.
# Override JWT_SECRET when running compose:
#   JWT_SECRET=your-dev-secret docker compose up -d
